{
  "name": "zendr",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel --filter @zendr/server... --filter @zendr/web dev --host",
    "dev:server": "pnpm --parallel --filter @zendr/server... dev",
    "dev:web": "pnpm --filter @zendr/web dev",
    "build": "pnpm --filter @zendr/web build && pnpm --filter @zendr/server... build",
    "start": "pnpm --filter @zendr/server start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=24.18.0"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.9.0",
      "onFail": "download"
    }
  },
  "volta": {
    "node": "24.18.0",
    "pnpm": "11.9.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0"
  },
  "lint-staged": {
    "**/*.{js,ts,tsx}": [
      "eslint --fix"
    ],
    "**/*.{json,yml,yaml,md}": [
      "prettier --write"
    ]
  }
}
